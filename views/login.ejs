<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>CoursePrep Login</title>
    
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%- include('header') %>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #f5f5f5;
        }

        /* Main container */
        .container {
            display: flex;
            height: 100vh;
            max-width: 1400px;
            margin: 0 auto;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
        }

        /* LEFT SIDE */
        .left {
            width: 50%;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background-color: white;
        }

        /* RIGHT SIDE */
        .right {
            width: 50%;
            background: linear-gradient(135deg, #0f3d2e, #1b5e4b);
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            padding: 60px 40px;
            position: relative;
        }

        .left h2 {
            font-size: 36px;
            color: #1a1a1a;
            margin-bottom: 15px;
            font-weight: 600;
        }

        .left>p {
            color: #666;
            font-size: 16px;
            margin-bottom: 40px;
            max-width: 400px;
            line-height: 1.6;
        }

        .right p:first-child {
            font-size: 28px;
            font-weight: 700;
            margin: 0 0 15px 0;
            text-align: center;
            line-height: 1.3;
            letter-spacing: -0.5px;
        }

        .right p:nth-child(2) {
            font-size: 18px;
            font-weight: 400;
            text-align: center;
            max-width: 450px;
            margin: 0 auto;
            line-height: 1.6;
            opacity: 0.9;
        }

        form {
            display: flex;
            flex-direction: column;
            width: 100%;
            max-width: 380px;
        }

        label {
            font-size: 14px;
            font-weight: 600;
            color: #333;
            margin-bottom: 6px;
        }

        input {
            padding: 14px 16px;
            margin-bottom: 20px;
            border-radius: 10px;
            border: 1.5px solid #e0e0e0;
            font-size: 15px;
            transition: all 0.3s ease;
        }

        input:focus {
            outline: none;
            border-color: #0f3d2e;
            box-shadow: 0 0 0 3px rgba(15, 61, 46, 0.1);
        }

        input::placeholder {
            color: #999;
        }

        .forgot {
            text-align: right;
            font-size: 14px;
            margin-bottom: 25px;
            color: #0f3d2e;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s ease;
        }

        .forgot:hover {
            color: #1b5e4b;
            text-decoration: underline;
        }

        button {
            padding: 16px;
            border: none;
            border-radius: 12px;
            background-color: #0f3d2e;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        button:hover {
            background-color: #145a44;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(15, 61, 46, 0.3);
        }

        button:active {
            transform: translateY(0);
        }

        .register {
            margin-top: 30px;
            color: #0f3d2e;
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            transition: color 0.3s ease;
            display: inline-block;
        }

        .register:hover {
            color: #1b5e4b;
            text-decoration: underline;
        }

        .contact {
            width: 100%;
            text-align: center;
            margin-top: auto;
        }

        .contact p {
            font-size: 18px !important;
            font-weight: 600 !important;
            margin-bottom: 20px !important;
            color: white !important;
            letter-spacing: 1px;
        }

        .contact-details {
            display: flex;
            justify-content: center;
            gap: 40px;
            flex-wrap: wrap;
        }

        .contact-details span {
            font-size: 15px;
            font-weight: 400;
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255, 255, 255, 0.1);
            padding: 12px 25px;
            border-radius: 50px;
            backdrop-filter: blur(5px);
            transition: all 0.3s ease;
        }

        .contact-details span:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: translateY(-3px);
        }

        .contact-details i {
            font-size: 18px;
            color: white;
        }

        /* Welcome section on right */
        .welcome-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            max-width: 500px;
        }

        /* Add a subtle pattern to right side */
        .right::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
            pointer-events: none;
        }

        /* Responsive adjustments */
        @media (max-width: 968px) {
            .container {
                flex-direction: column;
                height: auto;
                min-height: 100vh;
            }

            .left,
            .right {
                width: 100%;
                padding: 40px;
            }

            .right {
                min-height: 500px;
            }

            .contact {
                margin-top: 40px;
            }
        }

        @media (max-width: 480px) {

            .left,
            .right {
                padding: 30px 20px;
            }

            .contact-details {
                flex-direction: column;
                gap: 15px;
            }

            .contact-details span {
                justify-content: center;
            }

            .right p:first-child {
                font-size: 24px;
            }

            .right p:nth-child(2) {
                font-size: 16px;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <!-- LEFT WHITE SIDE -->
        <div class="left">
            <h2>Welcome Back!</h2>
            <p>Sign in to access your dashboard and continue optimizing your Interview Process.</p>
            <form action="/">
                <label for="email">Email</label>
                <input type="email" id="email" placeholder="Enter your email" required>
                <label for="password">Password</label>
                <input type="password" id="password" placeholder="Enter your password" required>
                <a href="/forgot-password" class="forgot">Forgot password?</a>
                <a href="/">
                    <button>Login</button>
                </a>
            </form>
            <a href="/register" class="register">Don't have an account? Register here</a>
        </div>

        <!-- RIGHT GREEN SIDE -->
        <div class="right">
            <div class="welcome-content">
                <p>Welcome to the Innovative World of QA!</p>
                <p>This website will help you dive into the world of innovation, Inspiration and Creativity</p>
            </div>

            <div class="contact">
                <p>Contact Us</p>
                <div class="contact-details">
                    <span><i class="fas fa-phone"></i> 01234-56789</span>
                    <span><i class="fas fa-envelope"></i> Helpcenter@gmail.com</span>
                </div>
            </div>
        </div>
    </div>
<%- include('footer') %>
</body>

</html>