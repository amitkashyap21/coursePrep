<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CoursePrep - Interview Preparation</title>

    <link rel="stylesheet" href="/css/style.css">

    <%- include('header') %>

        <style>
            /* Keep your existing CSS here or move to /public/css/style.css */
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: Arial, sans-serif;
            }

            body {
                background-color: #f4f7f6;
                color: #222;
            }

            .hero {
                display: flex;
                justify-content: center;
                align-items: center;
                flex-direction: column;
                text-align: center;
                padding: 100px 20px;
                color: white;
                background: linear-gradient(to bottom right, #0f3d2e, #1b5e4b);
            }

            .hero h1 {
                font-size: 40px;
                margin-bottom: 20px;
            }

            .hero p {
                max-width: 700px;
                font-size: 18px;
                line-height: 1.6;
                margin-bottom: 30px;
            }

            .buttons {
                display: flex;
                gap: 20px;
            }

            .buttons a {
                padding: 12px 25px;
                border-radius: 8px;
                text-decoration: none;
                font-weight: 600;
                transition: 0.3s;
            }

            .primary-btn {
                background: white;
                color: #0f3d2e;
            }

            .primary-btn:hover {
                background: #e8f5e9;
            }

            .secondary-btn {
                border: 2px solid white;
                color: white;
            }

            .secondary-btn:hover {
                background: rgba(255, 255, 255, 0.1);
            }

            .features {
                padding: 80px 60px;
                text-align: center;
            }

            .features h2 {
                margin-bottom: 40px;
                font-size: 28px;
                color: #0f3d2e;
            }

            .feature-box {
                display: flex;
                justify-content: space-around;
                flex-wrap: wrap;
                gap: 30px;
            }

            .card {
                background: white;
                padding: 30px;
                width: 300px;
                border-radius: 12px;
                box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
            }

            .card h3 {
                margin-bottom: 15px;
                color: #0f3d2e;
            }

            .card p {
                font-size: 14px;
                line-height: 1.6;
                color: #555;
            }
        </style>
</head>

<body>

    <div class="hero">
        <h1>Personalized Interview Preparation Platform</h1>
        <p>
            CoursePrep is a role-based web application that generates
            customized interview questions based on your academic stream
            or competitive exam. Prepare smarter with tailored content.
        </p>

        <div class="buttons">
            <% if (user) { %>
                <% if (user.role==='admin' ) { %>
                    <a href="/admin-dashboard" class="primary-btn">Manage Platform</a>
                    <a href="/profile" class="secondary-btn">System Stats</a>
                    <% } else { %>
                        <a href="/questions" class="primary-btn">Go to Tests</a>
                        <a href="/profile" class="secondary-btn">My Profile</a>
                        <% } %>
                            <% } else { %>
                                <a href="/register" class="primary-btn">Get Started</a>
                                <a href="/login" class="secondary-btn">Login</a>
                                <% } %>
        </div>
    </div>

    <div class="features">
        <h2>How The System Works</h2>
        <div class="feature-box">
            <div class="card">
                <h3>For Users</h3>
                <p>Enter your academic stream and instantly receive relevant interview questions curated to match your
                    goals.</p>
            </div>
            <div class="card">
                <h3>For Admins</h3>
                <p>Manage the question bank, upload JSON files, and oversee user activity through a secure dashboard.
                </p>
            </div>
            <div class="card">
                <h3>Smart & Scalable</h3>
                <p>Built with MongoDB and role-based access control to ensure secure and efficient content delivery.</p>
            </div>
        </div>
    </div>

    <%- include('footer') %>

        <script src="/js/firstpage.js"></script>

</body>

</html>