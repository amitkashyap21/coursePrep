<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= topic.toUpperCase() %> Quiz | CoursePrep</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <%- include('header') %>
    <style>
        :root {
            --primary-dark: #0f3d2e;
            --secondary-green: #1b5e4b;
            --bg-light: #f4f7f6;
        }

        body { background-color: var(--bg-light); }

        .quiz-container {
            max-width: 800px;
            margin: 50px auto;
            padding: 0 20px;
        }

        .quiz-header {
            background: white;
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .quiz-header h1 { color: var(--primary-dark); text-transform: uppercase; font-size: 24px; }

        .question-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 20px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.03);
            border-left: 5px solid var(--secondary-green);
        }

        .question-text { font-size: 18px; font-weight: 600; margin-bottom: 20px; color: #333; }

        .option-label {
            display: block;
            padding: 12px 15px;
            margin-bottom: 10px;
            border: 1.5px solid #eee;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.2s;
        }

        .option-label:hover { background: #f9fdfc; border-color: var(--secondary-green); }

        input[type="radio"] { margin-right: 12px; accent-color: var(--primary-dark); }

        .submit-section { text-align: center; margin-top: 40px; }

        .btn-submit {
            background: var(--primary-dark);
            color: white;
            padding: 15px 50px;
            border: none;
            border-radius: 10px;
            font-size: 18px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-submit:hover { background: var(--secondary-green); transform: translateY(-2px); }

        .btn-submit:disabled { background: #ccc; cursor: not-allowed; }
    </style>
</head>
<body>

<div class="quiz-container">
    <div class="quiz-header">
        <h1><%= topic %> Quiz</h1>
        <div style="color: #666;"><i class="fa-solid fa-file-lines"></i> <%= questions.length %> Questions</div>
    </div>

    <form id="quizForm">
        <% questions.forEach((q, index) => { %>
            <div class="question-card">
                <p class="question-text"><%= index + 1 %>. <%= q.question %></p>
                <div class="options">
                    <% q.options.forEach(option => { %>
                        <label class="option-label">
                            <input type="radio" 
                                   name="q<%= index %>" 
                                   value="<%= option %>" 
                                   data-correct="<%= q.answer %>" 
                                   data-question="<%= q.question %>" 
                                   required>
                            <%= option %>
                        </label>
                    <% }) %>
                </div>
            </div>
        <% }) %>

        <div class="submit-section">
            <button type="button" id="submitBtn" class="btn-submit" onclick="processQuiz()">
                Submit Assessment
            </button>
        </div>
    </form>
</div>

<%- include('footer') %>

<script>
async function processQuiz() {
    const form = document.getElementById('quizForm');
    const submitBtn = document.getElementById('submitBtn');
    
    // FIX: Wrap in quotes and convert to Number to avoid "Expression expected" error
    const totalQuestions = Number("<%= questions ? questions.length : 0 %>");
    const answered = form.querySelectorAll('input[type="radio"]:checked').length;

    if (answered < totalQuestions) {
        alert(`Please answer all ${totalQuestions} questions before submitting.`);
        return;
    }

    submitBtn.disabled = true;
    submitBtn.innerText = "Processing Score...";

    let score = 0;
    let results = [];

    const questionBlocks = document.querySelectorAll('.question-card');
    questionBlocks.forEach(block => {
        const selectedInput = block.querySelector('input[type="radio"]:checked');
        
        // Use getAttribute for better compatibility with data- attributes
        const questionText = selectedInput.getAttribute('data-question');
        const correctAnswer = selectedInput.getAttribute('data-correct');
        const userAnswer = selectedInput.value;
        const isCorrect = (userAnswer === correctAnswer);

        if (isCorrect) score++;

        results.push({
            question: questionText,
            userAnswer: userAnswer,
            correctAnswer: correctAnswer,
            status: isCorrect
        });
    });

    const urlParams = new URLSearchParams(window.location.search);
    try {
        const response = await fetch('/submit-quiz', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                username: urlParams.get('user'),
                topic: '<%= topic %>', // Injected as string safely
                score: score,
                results: results
            })
        });

        if (response.ok) {
            alert(`Assessment Complete! You scored ${score} out of ${totalQuestions}.`);
            window.location.href = `/profile?user=${urlParams.get('user')}&email=${urlParams.get('email')}`;
        } else {
            throw new Error("Failed to save");
        }
    } catch (err) {
        alert("Error saving score. Please try again.");
        submitBtn.disabled = false;
        submitBtn.innerText = "Submit Assessment";
    }
}
</script>

</body>
</html>