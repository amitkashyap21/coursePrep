<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('header') %>
        <style>
            :root {
                --primary-dark: #0f3d2e;
                --secondary-green: #1b5e4b;
                --bg-light: #f4f7f6;
            }

            body {
                background-color: var(--bg-light);
            }

            .quiz-container {
                max-width: 800px;
                margin: 50px auto;
                padding: 0 20px;
            }

            .question-card {
                background: white;
                padding: 30px;
                border-radius: 15px;
                margin-bottom: 20px;
                box-shadow: 0 4px 10px rgba(0, 0, 0, 0.03);
                border-left: 5px solid var(--secondary-green);
            }

            .option-label {
                display: block;
                padding: 12px 15px;
                margin-bottom: 10px;
                border: 1.5px solid #eee;
                border-radius: 8px;
                cursor: pointer;
            }

            .btn-submit {
                background: var(--primary-dark);
                color: white;
                padding: 15px 50px;
                border: none;
                border-radius: 10px;
                font-size: 18px;
                cursor: pointer;
            }

            .hidden {
                display: none;
            }
        </style>
</head>

<body>
    <div class="quiz-container" id="quiz-meta" data-topic="<%= topic %>" data-total-questions="<%= questions.length %>"
        data-room="<%= typeof room !== 'undefined' ? room : '' %>">

        <div class="quiz-header" style="background:white; padding:20px; border-radius:15px; margin-bottom:20px;">
            <h1>
                <%= topic.toUpperCase() %> Quiz
            </h1>
        </div>

        <form id="quizForm">
            <% questions.forEach((q, index)=> { %>
                <div class="question-card">
                    <p><strong>
                            <%= index + 1 %>. <%= q.question %>
                        </strong></p>
                    <% q.options.forEach((option)=> { %>
                        <label class="option-label">
                            <input type="radio" name="q<%= index %>" value="<%= option %>"
                                data-correct-index="<%= q.answer %>" data-question-text="<%= q.question %>" required>
                            <%= option %>
                        </label>
                        <% }) %>
                </div>
                <% }) %>
                    <div style="text-align:center;">
                        <button type="button" id="submitBtn" class="btn-submit">Submit Assessment</button>
                    </div>
        </form>
    </div>

    <%- include('footer') %>
        <script src="/socket.io/socket.io.js"></script>
        <script src="/js/quiz.js"></script>
</body>

</html>