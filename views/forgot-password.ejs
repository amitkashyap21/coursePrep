<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Reset Password | CoursePrep</title>
    <%- include('header') %>
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #f5f5f5;
        }

        .container {
            display: flex;
            height: 100vh;
        }

        /* LEFT SIDE */
        .left {
            width: 50%;
            padding: 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            box-sizing: border-box;
            background-color: white;
        }

        .left h2 {
            font-size: 32px;
            margin-bottom: 15px;
            color: #1a1a1a;
        }

        .left p {
            color: #666;
            margin-bottom: 30px;
            line-height: 1.6;
        }

        form {
            display: flex;
            flex-direction: column;
            width: 100%;
            max-width: 400px;
        }

        label {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #333;
        }

        input {
            padding: 14px;
            margin-bottom: 20px;
            border-radius: 8px;
            border: 1.5px solid #e0e0e0;
            font-size: 15px;
        }

        input:focus {
            outline: none;
            border-color: #0f3d2e;
            box-shadow: 0 0 0 3px rgba(15, 61, 46, 0.1);
        }

        .helper-text {
            font-size: 12px;
            color: #0f3d2e;
            margin-top: -15px;
            margin-bottom: 20px;
        }

        button {
            padding: 16px;
            border: none;
            border-radius: 10px;
            background-color: #0f3d2e;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            text-transform: uppercase;
        }

        button:hover {
            background-color: #145a44;
            transform: translateY(-2px);
        }

        .back-login {
            margin-top: 25px;
            display: inline-block;
            color: #0f3d2e;
            text-decoration: none;
            font-weight: 500;
        }

        .back-login:hover {
            text-decoration: underline;
        }

        /* RIGHT SIDE */
        .right {
            width: 50%;
            background: linear-gradient(135deg, #0f3d2e, #1b5e4b);
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 60px;
            box-sizing: border-box;
        }

        .right h1 {
            font-size: 36px;
            margin-bottom: 20px;
        }

        .right p {
            font-size: 18px;
            line-height: 1.6;
            opacity: 0.9;
        }

        .contact {
            margin-top: 40px;
        }

        .contact-details {
            display: flex;
            gap: 30px;
            font-size: 15px;
        }

        .contact-details span {
            background: rgba(255, 255, 255, 0.1);
            padding: 10px 20px;
            border-radius: 50px;
        }

        @media (max-width: 900px) {
            .container { flex-direction: column; }
            .left, .right { width: 100%; padding: 40px; }
        }
    </style>
</head>
<body>

<div class="container">

    <div class="left">
        <h2>Reset Your Password</h2>
        <p>
            Use one of your 8-character backup codes provided during registration 
            to verify your identity and set a new password.
        </p>

        <form action="/forgot-password" method="POST">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="Enter your email" required>

            <label for="code">Backup Code</label>
            <input type="text" id="code" name="code" placeholder="Enter 8-character code" required maxlength="8">
            <p class="helper-text">This code will be deactivated after use.</p>

            <label for="newPassword">New Password</label>
            <input type="password" id="newPassword" name="newPassword" placeholder="Enter new password" required>

            <button type="submit">Update Password</button>
        </form>

        <a href="/login" class="back-login">← Back to Login</a>
    </div>

    <div class="right">
        <div>
            <h1>Secure Your Interview Journey</h1>
            <p>
                Don’t worry! We’ll help you regain access so you can
                continue preparing for your dream interviews.
            </p>
        </div>

        <div class="contact">
            <h3>Contact Us</h3>
            <div class="contact-details">
                <span>📞 +91 98765 43210</span>
                <span>📧 support@interviewhub.com</span>
            </div>
        </div>
    </div>

</div>

<%- include('footer') %>

</body>
</html>