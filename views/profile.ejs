<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile | CoursePrep</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <%- include('header') %>

    <style>
      :root {
        --primary-dark: #0f3d2e;
        --secondary-green: #1b5e4b;
        --danger: #d9534f;
        --bg-light: #f4f7f6;
        --empty-gray: #ebedf0;
      }

      body {
        background-color: var(--bg-light);
        padding-bottom: 50px;
        font-family: 'Segoe UI', sans-serif;
      }

      .profile-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 0 20px;
      }

      .card,
      .analytics-card,
      .recovery-card,
      .activity-card {
        background: white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        margin-bottom: 30px;
      }

      .card {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      /* --- HEATMAP STYLES --- */
      .heatmap-wrapper {
        display: flex;
        margin-top: 10px;
      }

      .days-labels {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        margin-right: 10px;
        padding-top: 30px;
        /* Space for month labels */
        padding-bottom: 5px;
        font-size: 11px;
        color: #888;
      }

      .heatmap-main {
        flex-grow: 1;
        overflow-x: auto;
      }

      #month-labels {
        display: flex;
        font-size: 11px;
        color: #888;
        margin-bottom: 8px;
        height: 15px;
      }

      .heatmap-container {
        overflow-x: auto;
        scrollbar-width: none;
      }

      .heatmap-grid {
        display: grid;
        grid-template-rows: repeat(7, 14px);
        /* 7 days of the week */
        grid-auto-flow: column;
        grid-auto-columns: 14px;
        grid-gap: 3px;
      }

      .day-square {
        width: 14px;
        height: 14px;
        border-radius: 2px;
        background-color: var(--empty-gray);
        transition: outline 0.1s;
      }

      .day-square:hover {
        outline: 1px solid #555;
      }

      .active-1 {
        background-color: #9be9a8;
      }

      .active-2 {
        background-color: #40c463;
      }

      .active-3 {
        background-color: #30a14e;
      }

      .active-4 {
        background-color: #216e39;
      }

      /* --- OTHER STYLES --- */
      .quiz-card {
        background: white;
        border-radius: 12px;
        margin-bottom: 15px;
        border: 1px solid #e0e0e0;
        overflow: hidden;
      }

      .quiz-summary {
        padding: 18px 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
      }

      .quiz-details {
        display: none;
        padding: 20px 25px;
        border-top: 1px solid #eee;
        background: #fdfdfd;
      }

      .topic-badge {
        background: rgba(15, 61, 46, 0.1);
        color: var(--primary-dark);
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
      }

      .chart-container {
        position: relative;
        margin: 20px auto;
        height: 350px;
        width: 100%;
      }

      .text-success {
        color: #28a745;
      }

      .text-danger {
        color: #dc3545;
      }

      .btn-delete {
        background: none;
        border: 1.5px solid var(--danger);
        color: var(--danger);
        padding: 8px 15px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
      }

      .recovery-card {
        border-left: 5px solid var(--primary-dark);
      }

      .btn-regenerate {
        width: 100%;
        background: var(--primary-dark);
        color: white;
        padding: 12px;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.3s;
        margin-top: 15px;
      }

      .status-badge {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 700;
      }
    </style>
</head>

<body>
  <div id="profile-data" data-user-role="<%= role %>" data-user-email="<%= email %>"
    data-has-marks="<%= marks && marks.length > 0 %>">
  </div>

  <div class="profile-container">
    <!-- User Welcome Card -->
    <div class="card">
      <div class="user-meta">
        <h2 style="color: var(--primary-dark); margin-bottom: 5px;">Welcome, <%= username %>!</h2>
        <p style="color: #666; font-size: 14px;"><i class="fa-solid fa-envelope"></i>
          <%= email %>
        </p>
      </div>
      <div class="actions">
        <% if (role==='admin' ) { %>
          <span style="background: #e8f5e9; color: #2e7d32; padding: 8px 15px; border-radius: 8px; font-weight: 600;">
            <i class="fa-solid fa-user-shield"></i> Admin Mode
          </span>
          <% } else { %>
            <button class="btn-delete" id="deleteAccountBtn">Delete Account</button>
            <% } %>
      </div>
    </div>

    <% if (role !=='admin' ) { %>
      <!-- ACTIVITY HEATMAP SECTION -->
      <h3 style="color: var(--primary-dark); margin-bottom: 20px;"><i class="fa-solid fa-calendar-days"></i> Activity
        Status</h3>
      <div class="activity-card">
        <div class="heatmap-wrapper">
          <div class="days-labels">
            <span>Mon</span>
            <span>Wed</span>
            <span>Fri</span>
          </div>
          <div class="heatmap-main">
            <div id="month-labels"></div>
            <div class="heatmap-container">
              <div id="heatmap" class="heatmap-grid"></div>
            </div>
          </div>
        </div>
        <div
          style="display: flex; align-items: center; gap: 5px; margin-top: 15px; font-size: 12px; color: #888; justify-content: flex-end;">
          <span>Less</span>
          <div class="day-square"></div>
          <div class="day-square active-1"></div>
          <div class="day-square active-2"></div>
          <div class="day-square active-3"></div>
          <div class="day-square active-4"></div>
          <span>More</span>
        </div>
      </div>

      <!-- Security Section -->
      <h3 style="color: var(--primary-dark); margin-bottom: 20px;"><i class="fa-solid fa-shield-halved"></i> Security &
        Recovery</h3>
      <div class="recovery-card">
        <% const codes=(typeof backupCodes !=='undefined' ) ? backupCodes : []; const remaining=codes.filter(c=>
          !c.used).length; %>
          <div style="display: flex; justify-content: space-between;">
            <p>Backup Recovery Codes: <strong>
                <%= remaining %> / 6
              </strong></p>
          </div>
          <form action="/api/regenerate-codes" method="POST">
            <button type="submit" class="btn-regenerate">Regenerate Codes</button>
          </form>
      </div>

      <!-- Performance Chart -->
      <h3 style="color: var(--primary-dark); margin-bottom: 20px;"><i class="fa-solid fa-chart-line"></i> Your
        Performance</h3>
      <div class="analytics-card">
        <% if (marks && marks.length> 0) { %>
          <div class="chart-container"><canvas id="performanceChart"></canvas></div>
          <% } else { %>
            <p style="text-align: center; color: #888;">Complete a quiz to see stats!</p>
            <% } %>
      </div>

      <!-- Recent History -->
      <h3 style="color: var(--primary-dark); margin-bottom: 20px;"><i class="fa-solid fa-clock-rotate-left"></i> Recent
        Activity</h3>
      <% marks.slice().reverse().forEach((attempt, index)=> { %>
        <div class="quiz-card">
          <div class="quiz-summary"
            onclick="this.nextElementSibling.style.display = this.nextElementSibling.style.display === 'block' ? 'none' : 'block'">
            <span><span class="topic-badge">
                <%= attempt.topic %>
              </span>
              <%= attempt.date %>
            </span>
            <span>Score: <%= attempt.score %>/5 <i class="fa-solid fa-chevron-down"></i></span>
          </div>
          <div class="quiz-details">
            <% attempt.results.forEach(res=> { %>
              <p><strong>Q:</strong>
                <%= res.question %><br>
                  <span class="<%= res.status ? 'text-success' : 'text-danger' %>">
                    <%= res.userAnswer %>
                  </span>
              </p>
              <% }) %>
          </div>
        </div>
        <% }) %>
          <% } %>
  </div>

  <%- include('footer') %>
    <script src="/js/profile.js"></script>
</body>

</html>