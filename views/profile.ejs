<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile | CoursePrep</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <%- include('header') %>
        <style>
            :root {
                --primary-dark: #0f3d2e;
                --secondary-green: #1b5e4b;
                --danger: #d9534f;
                --bg-light: #f4f7f6;
            }

            body {
                background-color: var(--bg-light);
                padding-bottom: 50px;
            }

            .profile-container {
                max-width: 900px;
                margin: 40px auto;
                padding: 0 20px;
            }

            /* User Info Card */
            .card {
                background: white;
                border-radius: 15px;
                padding: 30px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
                margin-bottom: 30px;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .user-meta h2 {
                color: var(--primary-dark);
                margin-bottom: 5px;
            }

            .user-meta p {
                color: #666;
                font-size: 14px;
            }

            .actions .btn-delete {
                background: none;
                border: 1.5px solid var(--danger);
                color: var(--danger);
                padding: 8px 15px;
                border-radius: 8px;
                cursor: pointer;
                transition: 0.3s;
                font-weight: 600;
            }

            .actions .btn-delete:hover {
                background: var(--danger);
                color: white;
            }

            /* Quiz History Section */
            .history-title {
                margin-bottom: 20px;
                color: var(--primary-dark);
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .quiz-card {
                background: white;
                border-radius: 12px;
                margin-bottom: 15px;
                border: 1px solid #e0e0e0;
                overflow: hidden;
                transition: transform 0.2s;
            }

            .quiz-summary {
                padding: 18px 25px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                cursor: pointer;
                background: #fff;
            }

            .quiz-summary:hover {
                background: #fafafa;
            }

            .topic-badge {
                background: rgba(15, 61, 46, 0.1);
                color: var(--primary-dark);
                padding: 4px 12px;
                border-radius: 20px;
                font-weight: 700;
                text-transform: uppercase;
                font-size: 12px;
            }

            .score-text {
                font-weight: 600;
                color: #333;
            }

            /* Expandable Details */
            .quiz-details {
                display: none;
                /* Hidden by default */
                padding: 20px 25px;
                border-top: 1px solid #eee;
                background: #fdfdfd;
            }

            .result-row {
                padding: 12px 0;
                border-bottom: 1px solid #f0f0f0;
            }

            .result-row:last-child {
                border-bottom: none;
            }

            .status-icon {
                margin-right: 10px;
            }

            .text-success {
                color: #28a745;
            }

            .text-danger {
                color: #dc3545;
            }

            .correct-ans {
                display: block;
                font-size: 13px;
                color: #28a745;
                margin-top: 4px;
                font-weight: 600;
            }
        </style>
</head>

<body>

    <div class="profile-container">

        <div class="card">
            <div class="user-meta">
                <h2>Welcome, <%= username %>!</h2>
                <p><i class="fa-solid fa-envelope"></i>
                    <%= email %>
                </p>
            </div>
            <div class="actions">
                <button class="btn-delete" onclick="deleteAccount()">
                    <i class="fa-solid fa-trash-can"></i> Delete Account
                </button>
            </div>
        </div>

        <h3 class="history-title">
            <i class="fa-solid fa-clock-rotate-left"></i> Your Quiz History
        </h3>

        <% if (marks.length===0) { %>
            <div class="card" style="justify-content: center; flex-direction: column; gap: 15px;">
                <p style="color: #666;">You haven't attempted any quizzes yet.</p>
                <a href="/questions?user=<%= username %>&email=<%= email %>"
                    style="color: var(--primary-dark); font-weight: bold; text-decoration: none;">
                    Browse Topics →
                </a>
            </div>
            <% } else { %>
                <% marks.reverse().forEach((attempt, index)=> { %>
                    <div class="quiz-card">
                        <div class="quiz-summary" onclick="toggleDetails('quiz-<%= index %>')">
                            <div>
                                <span class="topic-badge">
                                    <%= attempt.topic %>
                                </span>
                                <span style="margin-left: 15px; color: #888; font-size: 13px;">
                                    <%= attempt.date %>
                                </span>
                            </div>
                            <div>
                                <span class="score-text">Score: <%= attempt.score %>/5</span>
                                <i class="fa-solid fa-chevron-down" style="margin-left: 15px; color: #ccc;"></i>
                            </div>
                        </div>

                        <div class="quiz-details" id="quiz-<%= index %>">
                            <% attempt.results.forEach(res=> { %>
                                <div class="result-row">
                                    <p style="font-size: 14px; margin-bottom: 5px;"><strong>Q:</strong>
                                        <%= res.question %>
                                    </p>
                                    <span class="status-icon <%= res.status ? 'text-success' : 'text-danger' %>">
                                        <i
                                            class="fa-solid <%= res.status ? 'fa-circle-check' : 'fa-circle-xmark' %>"></i>
                                        <%= res.userAnswer %>
                                    </span>
                                    <% if (!res.status) { %>
                                        <span class="correct-ans">Correct Answer: <%= res.correctAnswer %></span>
                                        <% } %>
                                </div>
                                <% }) %>
                        </div>
                    </div>
                    <% }) %>
                        <% } %>

    </div>

    <%- include('footer') %>



        <script>
            // Toggle the accordion for quiz details
            function toggleDetails(id) {
                const details = document.getElementById(id);
                const icon = details.previousElementSibling.querySelector('.fa-chevron-down');

                if (details.style.display === "block") {
                    details.style.display = "none";
                    icon.style.transform = "rotate(0deg)";
                } else {
                    details.style.display = "block";
                    icon.style.transform = "rotate(180deg)";
                }
            }

            // Handle account deletion via AJAX
            async function deleteAccount() {
                if (confirm("Warning: This will permanently delete your account and all quiz scores. Proceed?")) {
                    try {
                        const response = await fetch('/api/delete-account', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                email: '<%= email %>',
                                username: '<%= username %>'
                            })
                        });

                        if (response.ok) {
                            alert("Account successfully deleted.");
                            window.location.href = '/login';
                        }
                    } catch (err) {
                        alert("Error deleting account. Please try again.");
                    }
                }
            }
        </script>

</body>

</html>